# Remote validation generated stubs and extra logs
# The tracked launch_report.json and server_gpu0.log stay.
# ============================================================
remote_validation/gen_stub_*/
remote_validation/pipeline/
remote_validation/server_gpu1.log

# ============================================================
# Training output — ignore everything by default, then
# selectively un-ignore the two blessed reward model runs.
#
# Git will not descend into an ignored directory, so we must
# NOT ignore training_output/ itself. Instead we ignore its
# contents via a wildcard and negate the two blessed subdirs.
# ============================================================
training_output/*

# UN-IGNORE: Two blessed reward model training runs
#   reward_function_run      — first reward-function-validated BTRM run
#   reward_function_run_tnt_v2 — TNT v2 corrected scoring run
# These contain adapter weights, BTRM heads, training curves,
# validation logs, charts, analysis markdown, and checkpoints
# that others need for comparison and reproducibility.
!training_output/reward_function_run/
!training_output/reward_function_run_tnt_v2/

# UN-IGNORE: .safetensors inside the two blessed runs
# (overrides the global *.safetensors rule above)
!training_output/reward_function_run/**
!training_output/reward_function_run_tnt_v2/**ref_papers/
